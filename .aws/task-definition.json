{
  "family": "hotel-task",
  "executionRoleArn": "arn:aws:iam::603482306089:role/LabRole",
  "taskRoleArn": "arn:aws:iam::603482306089:role/LabRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "hotel-container",
      "image": "603482306089.dkr.ecr.us-east-1.amazonaws.com/hotel-booking-backend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "hotel-container-8080-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "JWT_SECRET",
          "value": "SG90ZWxCb29raW5nSldUMjAyNFNlY3JldEtleTEyMzQ="
        },
        {
          "name": "MYSQL_HOST",
          "value": "hotel-1.cftpj7xww7iw.us-east-1.rds.amazonaws.com"
        },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:mysql://hotel-1.cftpj7xww7iw.us-east-1.rds.amazonaws.com:3306/PinkFlowTest?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC"
        },
        {
          "name": "SPRING_JPA_HIBERNATE_DDL_AUTO",
          "value": "update"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:603482306089:secret:hotel-booking/db-credentials-Rc4KHB:password::"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:603482306089:secret:hotel-booking/db-credentials-Rc4KHB:username::"
        }
      ],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hotel-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": []
}
